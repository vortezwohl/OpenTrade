{
  "runtime_defaults": {
    "program_defaults": {
      "format": "table",
      "indicator_level": "advanced",
      "view": "observation",
      "trace_window": 32,
      "shared_backend_when_omitted": "auto"
    },
    "skill_recommended_defaults": {
      "format": "json",
      "indicator_level": "full",
      "view": "observation",
      "trace_window": 128,
      "backend_policy": "omit_backend_unless_user_explicitly_requests_or_debugging_requires_it"
    }
  },
  "top_level_commands": {
    "stock": {
      "special": false,
      "role": "股票相关查询。"
    },
    "fund": {
      "special": false,
      "role": "基金相关查询。"
    },
    "bond": {
      "special": false,
      "role": "债券相关查询。"
    },
    "futures": {
      "special": false,
      "role": "期货相关查询。"
    },
    "quote": {
      "special": false,
      "role": "已知 quote_id 时的跨资产统一行情入口。"
    },
    "market": {
      "special": false,
      "role": "市场级扫描与市场配置查询。"
    },
    "resolve": {
      "special": false,
      "role": "把 symbol 或关键字解析为 quote_id。"
    },
    "search": {
      "special": true,
      "role": "按关键字搜索候选标的。",
      "real_output_shape": "默认也会走 observation 渲染；JSON 模式通常输出候选项 observation payload。",
      "watch_supported": true
    },
    "watch": {
      "special": true,
      "role": "把支持的子命令包装成循环刷新任务。",
      "real_output_shape": "本身不查询业务数据，只负责把刷新参数转发给后续完整子命令。",
      "watch_supported": false,
      "options": [
        {
          "name": "interval",
          "cli_name": "interval",
          "required": false,
          "default": 2,
          "multiple": false,
          "annotation": "FloatParamType",
          "legal_values": "开放值；由上游 efinance 或兼容层解释",
          "description": "interval 参数。"
        },
        {
          "name": "count",
          "cli_name": "count",
          "required": false,
          "default": null,
          "multiple": false,
          "annotation": "IntParamType",
          "legal_values": "开放值；由上游 efinance 或兼容层解释",
          "description": "count 参数。"
        },
        {
          "name": "clear_screen",
          "cli_name": "clear",
          "required": false,
          "default": true,
          "multiple": false,
          "annotation": "BoolParamType",
          "legal_values": "开放值；由上游 efinance 或兼容层解释",
          "description": "clear 参数。"
        }
      ]
    }
  },
